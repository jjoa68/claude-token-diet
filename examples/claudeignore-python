# Python 프로젝트용 .claudeignore
# 이 파일을 프로젝트 루트에 .claudeignore로 복사하세요.
#
# 사용법:
#   cp claudeignore-python /path/to/your/project/.claudeignore

# 가상환경
.venv/
venv/
env/
.env/

# 바이트코드 / 캐시
__pycache__/
*.pyc
*.pyo
*.pyd

# 빌드 / 패키징
dist/
build/
*.egg-info/
*.egg
sdist/
wheels/

# 테스트
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# 타입 체크
.mypy_cache/
.pytype/

# 환경변수 (보안)
.env
.env.local

# IDE / 에디터
.idea/
.vscode/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# 시스템 파일
.DS_Store
Thumbs.db

# 바이너리 / 데이터
*.sqlite
*.db
*.csv
*.parquet
*.pkl
*.pickle
*.h5
*.hdf5

# 미디어
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf

# 문서 빌드
docs/_build/
site/
